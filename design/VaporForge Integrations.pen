                    },
                    {
                      "type": "text",
                      "id": "8MDmN",
                      "name": "fpDesc",
                      "fill": "#768390",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Targeted code review, security analysis, and PR feedback using three specialized agents.",
                      "lineHeight": 1.65,
                      "fontFamily": "Space Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "NIT15",
                      "name": "fpH2a",
                      "fill": "#cdd9e5",
                      "content": "When to use this skill",
                      "fontFamily": "Space Mono",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "phKcr",
                      "name": "fpBullets",
                      "fill": "#768390",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Before opening or merging a pull request\n• After writing authentication, encryption, or data-handling code\n• When refactoring a large module and want an independent review\n• To find dead code or consolidation opportunities before a release",
                      "lineHeight": 1.7,
                      "fontFamily": "Space Mono",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "Tzj7A",
