                      "content": "How to use this skill",
                      "fontFamily": "Space Mono",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "IdXMZ",
                      "name": "fpSteps",
                      "fill": "#768390",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "1. Run /review to analyze all staged changes\n2. Run /review-pr 42 to fetch and review an open PR by number\n3. The security agent auto-activates when auth or crypto files are touched\n4. Toggle individual agents on/off in the Components panel",
                      "lineHeight": 1.7,
                      "fontFamily": "Space Mono",
                      "fontSize": 10,
                      "fontWeight": "normal"
